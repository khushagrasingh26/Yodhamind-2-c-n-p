{
  "name": "yodhamind",
  "version": "1.0.0",
  "description": "Mental wellness platform for college students — stress management, cognitive games, self-assessments, and psychologist support.",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node api/server.js",
    "dev": "nodemon api/server.js --watch api --ext js,json",
    "db:migrate": "psql $DATABASE_URL -f api/db/schema.sql",
    "db:seed": "psql $DATABASE_URL -f api/db/seeds.sql",
    "db:reset": "npm run db:migrate && npm run db:seed",
    "lint": "eslint api/ --ext .js --fix",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "vercel-build": "echo 'Static pages — no build step needed'",
    "cleanup": "node api/tasks/cleanup.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "pino": "^9.2.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "pino-pretty": "^11.2.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "api/**/*.js",
      "!api/db/**"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": "warn"
    }
  }
}
