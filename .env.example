# ══════════════════════════════════════════════════════════
#  YodhaMind — Environment Variables
#  ─────────────────────────────────────────────────────────
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values    (never commit .env to git)
#  3. In production:    set these as Vercel / Railway env vars
# ══════════════════════════════════════════════════════════


# ── Server ────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=3001                     # local API port (Vercel ignores this)


# ── Database (PostgreSQL) ─────────────────────────────────
#
#   Local dev:
#     postgres://user:password@localhost:5432/yodhamind
#
#   Supabase (recommended for free tier):
#     Get from: Project → Settings → Database → Connection string
#
#   Neon (serverless Postgres, great for Vercel):
#     Get from: Neon console → Connection Details
#
DATABASE_URL=postgresql://user:password@localhost:5432/yodhamind

#   Optional — separate read replica (leave blank to use DATABASE_URL)
DATABASE_READ_URL=


# ── JWT Authentication ────────────────────────────────────
#
#   Generate a secure secret:
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
JWT_SECRET=replace_with_64_char_random_hex_string_never_share_this
JWT_EXPIRES_IN=7d             # token TTL — e.g. 1h, 7d, 30d
JWT_REFRESH_EXPIRES_IN=30d    # refresh token TTL


# ── CORS ─────────────────────────────────────────────────
#   Dev:        * (allow all)
#   Production: your actual domain, e.g. https://yodhamind.vercel.app
CORS_ORIGIN=*


# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes (in ms)
RATE_LIMIT_MAX=100            # requests per window per IP
AUTH_RATE_LIMIT_MAX=10        # stricter limit for /api/auth/* routes


# ── Anthropic API (AI Advisor) ────────────────────────────
#
#   IMPORTANT: This key is used by the backend proxy route
#   /api/advisor/chat — it is NEVER sent to the browser.
#   Get yours: https://console.anthropic.com
#
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-your-real-key
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024


# ── Email / Notifications (optional) ─────────────────────
#
#   Used for: appointment confirmation, streak reminders
#   Supported providers: smtp | sendgrid | resend
#
MAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false             # true for port 465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password   # Gmail: use App Password, not account password
MAIL_FROM="YodhaMind <noreply@yodhamind.app>"


# ── Cloudinary (profile photos — optional) ───────────────
#   Sign up free at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Moderation ───────────────────────────────────────────
#   Anonymous community posts are hashed with this salt
#   so session IDs are non-reversible but consistent
ANON_SALT=replace_with_any_random_string_32_chars_min


# ── Institution (optional multi-tenant) ───────────────────
#   Set to a college code if deploying for a single institution.
#   Leave as DEFAULT for the public/multi-college version.
INSTITUTION_CODE=DEFAULT
